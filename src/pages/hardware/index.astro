---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import HardwareGrid from "../../components/hardware/HardwareGrid.astro";

const items = await getCollection("hardware");
const sorted = items.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});
---

<PageLayout
  title="Hardware"
  description="Sprzęt pomiarowy Agro-Merge — stacje pogodowe, sensory wilgotności gleby, moduły GPS."
  heading="Hardware"
  subheading="Niezawodny sprzęt do zbierania danych z pola — stacje pogodowe, sensory i moduły GPS."
>
  <HardwareGrid items={sorted} />
</PageLayout>
