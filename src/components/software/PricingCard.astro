---
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

interface Props {
  title: string;
  description: string;
  price?: string;
  features: string[];
  tier: "starter" | "pro" | "enterprise";
  href: string;
  highlighted?: boolean;
}

const { title, description, price, features, tier, href, highlighted = false } =
  Astro.props;

const tierLabels = {
  starter: "Starter",
  pro: "Pro",
  enterprise: "Enterprise",
};
---

<div
  class:list={[
    "rounded-2xl border p-8 flex flex-col bg-white",
    highlighted
      ? "border-agro-gold shadow-lg ring-2 ring-agro-gold/20"
      : "border-agro-gold/15",
  ]}
>
  <div class="flex items-center justify-between mb-4">
    <Badge variant={highlighted ? "primary" : "default"}>{tierLabels[tier]}</Badge>
    {highlighted && <span class="text-xs font-semibold text-agro-copper">Popularny</span>}
  </div>
  <h3 class="text-2xl font-bold text-agro-primary">{title}</h3>
  <p class="mt-2 text-agro-primary/60 text-sm">{description}</p>
  {
    price && (
      <p class="mt-6 text-3xl font-bold text-agro-copper">
        {price}
        <span class="text-sm font-normal text-agro-primary/50"> / rok</span>
      </p>
    )
  }
  <ul class="mt-6 space-y-3 flex-1">
    {
      features.map((feature) => (
        <li class="flex items-start gap-2 text-sm text-agro-primary/80">
          <svg
            class="w-4 h-4 text-agro-gold mt-0.5 shrink-0"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
              clip-rule="evenodd"
            />
          </svg>
          {feature}
        </li>
      ))
    }
  </ul>
  <div class="mt-8">
    <Button href={href} variant={highlighted ? "primary" : "outline"} class="w-full">
      Dowiedz się więcej
    </Button>
  </div>
</div>
