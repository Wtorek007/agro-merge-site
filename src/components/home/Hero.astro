---
import Button from "../ui/Button.astro";
import Logo from "../layout/Logo.astro";

const steps = [
  "Pozyskanie danych",
  "Analiza możliwości",
  "Projekt rozwiązania",
  "Kalibracja i montaż",
  "Optymalne plony",
];
---

<section
  class="relative min-h-[90vh] flex items-center bg-gradient-to-br from-agro-primary via-agro-surface to-agro-primary-dark text-white overflow-hidden"
>
  <div
    class="absolute inset-0 opacity-5"
    style="background-image: radial-gradient(circle at 25% 25%, #c5a059 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <div class="container mx-auto px-6 py-24 relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10 lg:gap-8 xl:gap-12">
      <div class="min-w-0 flex-1 lg:max-w-[58%] xl:max-w-[52rem]">
        <p class="text-agro-gold uppercase tracking-widest text-sm mb-4 font-medium">
          AGRO-IT
        </p>
        <h1 class="text-3xl sm:text-4xl lg:text-[2rem] xl:text-[2.375rem] 2xl:text-[2.5rem] font-bold leading-snug max-w-2xl lg:max-w-none">
          Projektujemy architekturę jutra dla współczesnego rolnictwa. Integrujemy sprzęt i
          oprogramowanie, automatyzując procesy tam, gdzie ziemia wymaga najwyższej precyzji.
        </h1>
        <p class="mt-4 font-script text-agro-gold text-xl md:text-2xl italic">
          Merging wisdom for the better yields
        </p>
        <p class="mt-6 text-xl text-white/75 max-w-2xl leading-relaxed">
          Stacje pomiarowe, sensory i licencje software — kompletne rozwiązanie od pola do dashboardu.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="/hardware" variant="primary" size="lg">
            Zobacz Hardware
          </Button>
          <a
            href="/software"
            class="inline-flex items-center justify-center px-8 py-4 border border-agro-gold/50 text-agro-gold rounded-lg font-semibold hover:bg-agro-gold/10 transition-colors"
          >
            Licencje Software
          </a>
        </div>
      </div>

      <div class="hidden lg:flex shrink-0 justify-center items-center pl-4 xl:pl-8">
        <Logo variant="hero" />
      </div>
    </div>

    <div class="mt-16 lg:mt-20 pt-10 border-t border-agro-gold/15">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-8 lg:gap-6 xl:gap-5">
        {
          steps.map((label, i) => (
            <div class="flex flex-col sm:items-start xl:items-center xl:text-center">
              <span class="text-xl md:text-2xl font-bold tracking-wide text-agro-gold/75 leading-snug">
                {label}
              </span>
              <span class="mt-2 text-[0.7rem] uppercase tracking-[0.2em] text-agro-copper/60 font-mono">
                Krok-{i + 1}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
