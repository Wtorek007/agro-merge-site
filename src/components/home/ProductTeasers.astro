---
import SectionHeading from "../ui/SectionHeading.astro";
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";

const products = [
  {
    title: "Hardware",
    description:
      "Stacje pogodowe, sensory wilgotności gleby, moduły GPS i urządzenia IoT — niezawodny sprzęt do zbierania danych z pola.",
    href: "/hardware",
    badge: "Sprzęt",
    icon: "🔧",
  },
  {
    title: "Software",
    description:
      "Licencje platformy analitycznej, dashboardy, alerty i raporty — oprogramowanie, które zamienia dane w decyzje.",
    href: "/software",
    badge: "Licencje",
    icon: "💻",
  },
];
---

<section class="py-20 bg-agro-muted">
  <div class="container mx-auto px-6">
    <SectionHeading
      title="Co oferujemy"
      subtitle="Kompletne rozwiązanie łączące sprzęt pomiarowy z platformą analityczną."
      centered
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {
        products.map((product) => (
          <Card href={product.href} class="border-agro-gold/15 hover:border-agro-gold/30">
            <div class="p-8">
              <div class="flex items-center justify-between mb-4">
                <span class="text-4xl">{product.icon}</span>
                <Badge variant="primary">{product.badge}</Badge>
              </div>
              <h3 class="text-2xl font-bold text-agro-primary">{product.title}</h3>
              <p class="mt-3 text-agro-primary/70 leading-relaxed">{product.description}</p>
              <span class="mt-6 inline-flex items-center text-agro-copper font-semibold text-sm">
                Dowiedz się więcej
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </span>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>
