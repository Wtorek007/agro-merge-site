---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = false, light = false } = Astro.props;
---

<div class:list={["mb-12", centered && "text-center"]}>
  <h2
    class:list={[
      "text-3xl md:text-4xl font-bold",
      light ? "text-white" : "text-agro-primary",
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={[
          "mt-4 text-lg",
          light ? "text-white/70" : "text-agro-primary/60",
          centered && "max-w-2xl mx-auto",
        ]}
      >
        {subtitle}
      </p>
    )
  }
</div>
