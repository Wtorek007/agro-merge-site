---
import type { CollectionEntry } from "astro:content";

interface Props {
  report: CollectionEntry<"amis-reports">;
}

const { report } = Astro.props;
const { title, summary, date } = report.data;

const formattedDate = date.toLocaleDateString("pl-PL", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="expert-report">
  <time class="expert-report__date" datetime={date.toISOString()}>
    {formattedDate}
  </time>
  <h3 class="expert-report__title">{title}</h3>
  <p class="expert-report__summary">{summary}</p>
  <p class="expert-report__link">Czytaj pełną analizę →</p>
</article>

<style>
  .expert-report {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-agro-gold) 14%, transparent);
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-agro-primary) 6%, transparent);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .expert-report:hover {
    border-color: color-mix(in srgb, var(--color-agro-gold) 35%, transparent);
    box-shadow: 0 12px 28px color-mix(in srgb, var(--color-agro-primary) 10%, transparent);
    transform: translateY(-2px);
  }

  .expert-report__date {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-agro-copper);
  }

  .expert-report__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2.5vw, 1.35rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-agro-primary);
  }

  .expert-report__summary {
    margin: 0;
    flex: 1;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-agro-primary) 72%, transparent);
  }

  .expert-report__link {
    margin-top: auto;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-agro-copper);
  }
</style>
