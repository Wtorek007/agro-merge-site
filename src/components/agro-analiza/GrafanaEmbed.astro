---
interface Props {
  src?: string;
  title: string;
  height?: number;
}

const { src, title, height = 480 } = Astro.props;

function buildEmbedUrl(url: string) {
  const suffix = "theme=light&kiosk=1";
  return url.includes("?") ? `${url}&${suffix}` : `${url}?${suffix}`;
}

const isPublicDashboard = src?.includes("/public-dashboards/") ?? false;
const embedUrl = src && !isPublicDashboard ? buildEmbedUrl(src) : undefined;
const panelHeight = isPublicDashboard ? Math.max(height, 420) : height;
---

<div class="rounded-2xl border border-agro-gold/15 bg-white overflow-hidden shadow-sm">
  <div class="flex items-center justify-between px-4 py-3 bg-agro-muted border-b border-agro-gold/10">
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-orange-500"></span>
      <span class="text-xs font-semibold uppercase tracking-wider text-agro-primary/60">
        Grafana
      </span>
    </div>
    <p class="text-sm font-medium text-agro-primary truncate max-w-[60%]">{title}</p>
  </div>

  {
    isPublicDashboard && src ? (
      <div
        class="relative flex flex-col items-center justify-center text-center px-8 py-12 bg-gradient-to-br from-agro-muted to-white"
        style={`min-height: ${panelHeight}px`}
      >
        <div
          class="absolute inset-0 opacity-[0.04]"
          style="background-image: radial-gradient(circle at 25% 25%, #c5a059 1px, transparent 1px); background-size: 24px 24px;"
        />
        <div class="relative z-10 max-w-lg">
          <div class="mx-auto w-16 h-16 rounded-2xl bg-agro-gold/15 flex items-center justify-center mb-6">
            <svg
              class="w-8 h-8 text-agro-copper"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-agro-primary">{title}</h3>
          <p class="mt-3 text-sm text-agro-primary/60 leading-relaxed">
            Interaktywny dashboard Grafana Cloud. Ze względów bezpieczeństwa Grafana
            nie pozwala na osadzenie publicznego dashboardu w ramce na stronie zewnętrznej
            — otwórz go w dedykowanej karcie.
          </p>
          <a
            href={src}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex items-center justify-center gap-2 px-8 py-4 bg-agro-gold text-agro-primary font-semibold rounded-lg hover:bg-agro-gold-light transition-colors"
          >
            Otwórz interaktywny dashboard
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        </div>
      </div>
    ) : embedUrl ? (
      <iframe
        src={embedUrl}
        title={title}
        width="100%"
        height={panelHeight}
        loading="lazy"
        class="block w-full border-0 bg-white"
        allow="fullscreen"
      />
    ) : (
      <div
        class="flex flex-col items-center justify-center text-center px-6 bg-agro-muted/50"
        style={`min-height: ${panelHeight}px`}
      >
        <svg
          class="w-12 h-12 text-agro-gold/60 mb-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
          />
        </svg>
        <p class="text-agro-primary font-semibold">Dashboard Grafana w przygotowaniu</p>
        <p class="mt-2 text-sm text-agro-primary/60 max-w-md">
          Panel zostanie osadzony po podłączeniu instancji Grafana. Skonfiguruj pole
          <code class="text-agro-copper">grafanaUrl</code> w pliku analizy.
        </p>
      </div>
    )
  }
</div>
