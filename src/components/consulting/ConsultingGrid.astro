---
import type { CollectionEntry } from "astro:content";
import Card from "../ui/Card.astro";

interface Props {
  items: CollectionEntry<"consulting">[];
}

const { items } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {
    items.map((item) => (
      <Card href={`/consulting-it/${item.id}`} class="h-full">
        <div class="p-6 h-full flex flex-col">
          {item.data.icon && (
            <span class="text-3xl mb-4">{item.data.icon}</span>
          )}
          <h3 class="text-xl font-bold text-agro-primary">{item.data.title}</h3>
          <p class="mt-3 text-agro-primary/70 text-sm leading-relaxed flex-1">
            {item.data.description}
          </p>
          <span class="mt-6 inline-flex items-center text-agro-copper font-semibold text-sm">
            Czytaj więcej
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </span>
        </div>
      </Card>
    ))
  }
</div>
