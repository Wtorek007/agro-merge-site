---
interface Props {
  variant?: "header" | "footer" | "hero";
}

const { variant = "header" } = Astro.props;

const sizes = {
  header: "h-14 w-auto max-w-[140px]",
  footer: "h-24 w-auto max-w-[200px]",
  hero: "h-56 md:h-72 w-auto max-w-[320px]",
};
---

<a href="/" class="inline-flex items-center group">
  <img
    src="/images/logo.png"
    alt="AGRO-IT.COM — Merging wisdom for the better yields"
    class={`${sizes[variant]} object-contain`}
    width="558"
    height="447"
    loading={variant === "hero" ? "eager" : "lazy"}
  />
</a>
