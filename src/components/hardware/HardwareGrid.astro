---
import type { CollectionEntry } from "astro:content";
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";

interface Props {
  items: CollectionEntry<"hardware">[];
}

const { items } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {
    items.map((item) => (
      <Card href={`/hardware/${item.id}`}>
        <div class="p-6">
          {item.data.featured && <Badge variant="primary">Polecany</Badge>}
          <h3 class="mt-3 text-xl font-bold text-gray-900">{item.data.title}</h3>
          <p class="mt-2 text-gray-600 text-sm leading-relaxed">
            {item.data.description}
          </p>
          {
            item.data.specs && item.data.specs.length > 0 && (
              <ul class="mt-4 space-y-1">
                {item.data.specs.slice(0, 3).map((spec) => (
                  <li class="text-xs text-gray-500">
                    <span class="font-medium text-gray-700">{spec.label}:</span>{" "}
                    {spec.value}
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </Card>
    ))
  }
</div>
